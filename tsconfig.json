{
    "compilerOptions": {
        "baseUrl": ".",
        "module": "ESNext",
        "target": "ES2018",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "bundler",
        "types": ["node"],
        "importHelpers": false,
        "alwaysStrict": true,
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "lib": ["ES2018", "DOM", "ES2021.WeakRef"],
        "strictBindCallApply": true,
        "strictFunctionTypes": true,
        "paths": {
            "@/*": ["src/*"]
        }
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
