# Whitelist .gitignore: deny everything by default, opt in explicitly.
# Any new file or directory created in the project root is ignored unless
# listed below. This is defense-in-depth against accidental commits of
# editor state, secrets, build output, etc.
#
# When adding a new tracked file/dir at the repo root, add a matching
# `!/<path>` line here.

# Deny everything at the repo root.
/*

# Allow the whitelist itself and the top-level source/test/docs trees.
!/.gitignore
!/.github/
!/src/
!/tests/
!/scripts/

# Publish ONLY specific docs files. `!/docs/` lets git descend into the
# tree, `/docs/*` re-ignores everything in it, then each `!/docs/<file>`
# opts a single file back in. The rest of docs/ (internal design notes,
# private runbooks) stays unpublished. Do NOT add a broad `!/docs/**`.
!/docs/
/docs/*
!/docs/SETTINGS.md

# Allow top-level project metadata and config files.
!/LICENSE
!/README.md
!/SECURITY.md
!/CHANGELOG.md
!/package.json
!/package-lock.json
!/tsconfig.json
!/esbuild.config.mjs
!/vitest.config.ts
!/vitest.e2e.config.ts
!/docker-compose.yml
!/manifest.json
!/styles.css

# Re-apply blacklist entries for things that WOULD otherwise be allowed
# inside the whitelisted trees above (build artefacts, runtime data,
# per-machine settings, secrets).
node_modules/
main.js
*.js.map
meta.json
meta-*.json
data.json
.env
.env.*
*.local
