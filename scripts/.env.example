# CouchSync remote inspection — credentials template.
#
# Copy this file to `scripts/.env` (which is gitignored) and fill in your
# real CouchDB credentials. NEVER commit `scripts/.env` — only this
# template (`.env.example`) belongs in git.
#
# Used by:
#   node scripts/inspect-remote.mjs
#   node scripts/inspect-remote.mjs <docId>
#   node scripts/inspect-remote.mjs --prefix file:
#
# Example value (DO NOT use this — replace with your own):
#   COUCHSYNC_URI=https://couchdb.example.com:6984
#   COUCHSYNC_USER=alice
#   COUCHSYNC_PASSWORD=hunter2
#   COUCHSYNC_DB=obsidian

COUCHSYNC_URI=<https://your-couchdb-host:6984>
COUCHSYNC_USER=<your-couchdb-user>
COUCHSYNC_PASSWORD=<your-couchdb-password>
COUCHSYNC_DB=<your-vault-database-name>
# Optional — only needed when running `inspect-remote.mjs --target config`.
# Set this to the same value you use in CouchSync's Config Sync tab.
COUCHSYNC_CONFIG_DB=<your-config-database-name>
